__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.worktrees/
ui/uploads/

# never commit real credentials (.env.example is the template, .env is the secret)
.env
.env.*
!.env.example

# UI: thumbnails are derived and disposable; prebuilt/ is checked in on purpose

# transient claim markers / partial writes from the swarm cache
ui/prebuilt/*.lock
ui/prebuilt/*.tmp

# Managed-agents local run state (account/workspace-specific — never shared)
.environment_id
.interpreter_id
.coordinator_id
.specialist_ids.json
.skill_ids.json
.last_session_id
.vercel
.env*
