ANTHROPIC_API_KEY=sk-ant-...

# Everything below is only needed to deploy the gallery, not to run it locally.
# Without these, uploads still work with no login required (see ui/auth.py) and
# storage stays on local disk (see ui/storage.py) -- exactly today's dev experience.

# Google OAuth client (Web application), gating who can upload a drawing. Create one
# in the Google Cloud console; the authorized redirect URI is <your-domain>/auth/callback.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Signs the session cookie that remembers who's signed in. Any long random string;
# generate one with e.g. `python3 -c "import secrets; print(secrets.token_hex(32))"`.
# Required if GOOGLE_CLIENT_ID is set -- auth.py raises at startup otherwise.
# SESSION_SECRET=

# Comma-separated. Whoever signs in with a Google Workspace account on one of these
# domains can upload. Not hardcoded because the org is mid-rename from fractional.ai
# to ode.com and may need to add the new domain without a code change.
# ALLOWED_EMAIL_DOMAINS=fractional.ai,ode.com

# BLOB_READ_WRITE_TOKEN is auto-injected by Vercel once a Blob store is linked to the
# project -- don't set it by hand locally. Its presence is what switches
# ui/storage.py from local disk to Vercel Blob (see default_storage() in
# ui/storage.py). BLOB_STORE_ID is NOT injected and isn't needed -- the token embeds
# the store id and BlobStorage derives it. Set it only to point at a store other than
# the token's own, which is a thing you'd have to want on purpose.
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=

# --- observability (optional everywhere, including in production) ---
# Logfire. Without LOGFIRE_TOKEN nothing is exported: spans are still created and still
# nest, they just go nowhere, so the gallery and the test suite behave identically with
# and without it (see lib/telemetry.py). LOGFIRE_BASE_URL is only needed for a non-default
# region -- ours is US. Set ODE_TELEMETRY=off to skip instrumentation entirely; the test
# suite sets it so a developer with a token exported can't ship test traces.
# LOGFIRE_TOKEN=
# LOGFIRE_BASE_URL=https://api-us.pydantic.dev
